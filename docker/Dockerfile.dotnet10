FROM mcr.microsoft.com/dotnet/sdk:10.0

ENV DOTNET_CLI_TELEMETRY_OPTOUT=1 \
    DOTNET_NOLOGO=1 \
    DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1 \
    DOTNET_CLI_HOME=/tmp \
    NUGET_PACKAGES=/nuget/packages

RUN mkdir -p /nuget/packages /tmp/mstest-warmup && \
    useradd --create-home --shell /usr/sbin/nologin benchmark

WORKDIR /tmp/mstest-warmup

RUN dotnet new classlib --framework net10.0 --name Solution && \
    mkdir -p Solution.Tests && \
    printf '%s\n' \
      '<Project Sdk="Microsoft.NET.Sdk">' \
      '  <PropertyGroup>' \
      '    <TargetFramework>net10.0</TargetFramework>' \
      '    <ImplicitUsings>enable</ImplicitUsings>' \
      '    <Nullable>enable</Nullable>' \
      '    <IsPackable>false</IsPackable>' \
      '  </PropertyGroup>' \
      '  <ItemGroup>' \
      '    <ProjectReference Include="..\Solution\Solution.csproj" />' \
      '  </ItemGroup>' \
      '  <ItemGroup>' \
      '    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />' \
      '    <PackageReference Include="MSTest.TestAdapter" Version="3.9.3" />' \
      '    <PackageReference Include="MSTest.TestFramework" Version="3.9.3" />' \
      '    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.0" />' \
      '    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.0" />' \
      '  </ItemGroup>' \
      '</Project>' \
      > Solution.Tests/Solution.Tests.csproj && \
    dotnet restore Solution.Tests/Solution.Tests.csproj

WORKDIR /workspace
USER benchmark
